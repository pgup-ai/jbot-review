# jbot-review worker — systemd unit for the VPS (Model 1: native node process).
# Outbound-only: it polls the control plane and posts reviews; no inbound port.
#
# Install:
#   cp deploy/jbot-review-worker.service /etc/systemd/system/
#   # /etc/jbot-review-worker.env (chmod 600) holds ONLY:
#   #   CONTROL_PLANE_URL=https://<control-plane>
#   #   WORKER_SHARED_SECRET=<same value as the control plane>
#   #   WORKER_POLL_MS=5000
#   systemctl daemon-reload && systemctl enable --now jbot-review-worker

[Unit]
Description=jbot-review worker (polls the control plane, runs reviews)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/jbot-review
EnvironmentFile=/etc/jbot-review-worker.env
# /usr/local/bin so the review's child processes find the global `opencode`.
Environment=PATH=/usr/local/bin:/usr/bin:/bin
ExecStart=/usr/bin/node /opt/jbot-review/dist/worker/index.js
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
# Runs as a dedicated non-root user — the worker clones untrusted PR code and
# runs opencode, so it must not be root. Create the user first (deploy/README.md
# §3); the unit won't start until it exists. (To run as root anyway, comment this.)
User=jbot-worker

[Install]
WantedBy=multi-user.target

# jbot-review-worker.env.local — TEMPLATE (copy to jbot-review-worker.env.local)
#
# Consumed by deploy/ship-worker.sh, which writes /etc/jbot-review-worker.env on
# the VPS. The real file (without .example) is gitignored. Contains NO provider
# keys, ever — only the control-plane URL, the shared bearer secret, and the host.

# Where the worker reaches the control plane. Must be https:// (localhost allowed).
#   Local testing: your stable cloudflared/ngrok tunnel to jbot-review-app api :3001
#   Prod:          the Render api URL
CONTROL_PLANE_URL=

# MUST equal jbot-review-app/apps/api/.env  WORKER_SHARED_SECRET  (>= 32 chars).
WORKER_SHARED_SECRET=

# SSH host alias for the VPS (see ~/.ssh/config). Defaults to jbot-vps.
VPS_HOST=jbot-vps

# Poll interval (ms). Default 5000.
WORKER_POLL_MS=5000

{
  "name": "jbot-review",
  "version": "0.1.0",
  "description": "Agentic PR reviewer: opencode serve + SDK, with a gated inline-posting step.",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "build": "npx tsx scripts/build.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --deny-warnings",
    "dev": "tsx src/app/server.ts",
    "start": "npx tsx src/app/server.ts",
    "replay": "tsx scripts/replay-review.ts",
    "bench:golden": "tsx scripts/bench-golden.ts",
    "bench:golden:case": "tsx scripts/bench-golden.ts --case fms-3064-ai-chat-duplicate-review --model opencode/deepseek-v4-flash-free",
    "bench:golden:all": "tsx scripts/bench-golden.ts --all --model opencode/deepseek-v4-flash-free",
    "eval": "tsx scripts/eval-review.ts"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/webhooks": "^14.2.0",
    "@opencode-ai/sdk": "^1.17.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}

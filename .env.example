# Required for the hosted webhook App (`npm run dev`). NOT needed for
# `npm run review:local` — local review runs with the provider key alone.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Provider (defaults to opencode if unset)
# See src/shared/config.ts for all supported providers. Above each key:
# its format and where to create it.
PROVIDER=opencode
# oc-…/sk-… — https://opencode.ai (Zen; PROVIDER=opencode-go reuses this key)
OPENCODE_API_KEY=
# sk-… — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# sk-… — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# sk-ant-… — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# AIza… — https://aistudio.google.com/apikey (PROVIDER=google)
GEMINI_API_KEY=
# sk-or-… — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# nvapi-… — https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=
# one key for Coding Plan + pay-as-you-go — https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=
# xai-… — https://console.x.ai (xai provider, or grok when GROK_AUTH_JSON is empty)
XAI_API_KEY=
# tp-…/sk-…, region-locked (we run Singapore) — https://platform.xiaomimimo.com/#/console/plan-manage
MIMO_API_KEY=
# fw_… — https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=
# devin-session-token$… — `devin auth login`, then windsurf_api_key from ~/.local/share/devin/credentials.toml
DEVIN_WINDSURF_API_KEY=
# user_… — https://commandcode.ai/docs/quickstart (also in ~/.commandcode/auth.json)
COMMANDCODE_ACCESS_KEY=
# crsr_… — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
# Qoder account → Integrations → Personal Access Token — https://qoder.com/account/integrations
QODER_PERSONAL_ACCESS_TOKEN=
# CLI-backend auth blobs are JSON — keep them on ONE line here (minified);
# a `.env` value ends at the newline. Pasted a pretty-printed blob? Run
# `npm run env:minify-auth` to fold it back to one line. Or export it in the
# shell instead: `export CODEX_AUTH_JSON="$(cat ~/.codex/auth.json)"`.
# `codex login` (ChatGPT Plus/Pro) → whole ~/.codex/auth.json
CODEX_AUTH_JSON=
# `cline auth` → whole ~/.cline/data/settings/providers.json (cline + cline-pass)
CLINE_AUTH_JSON=
# `grok login --device-auth` → whole ~/.grok/auth.json; preferred over XAI_API_KEY for grok
GROK_AUTH_JSON=
# `kilo auth login` → whole ~/.local/share/kilo/auth.json
KILO_AUTH_CONTENT=

# Optional (defaults to provider default model)
# MODEL is <provider>/<model id>; some ids contain more slashes. Combos:
#   PROVIDER=opencode         MODEL=opencode/deepseek-v4-flash-free
#   PROVIDER=opencode-go      MODEL=opencode-go/deepseek-v4-flash
#   PROVIDER=deepseek         MODEL=deepseek/deepseek-v4-flash
#   PROVIDER=openai           MODEL=openai/gpt-5.4-nano
#   PROVIDER=anthropic        MODEL=anthropic/claude-sonnet-4-6
#   PROVIDER=google           MODEL=google/gemini-2.5-flash
#   PROVIDER=openrouter       MODEL=openrouter/openai/gpt-4o-mini            (openrouter/<vendor>/<model>)
#   PROVIDER=nvidia           MODEL=nvidia/nemotron-3-ultra-550b-a55b
#   PROVIDER=zai-coding-plan  MODEL=zai-coding-plan/glm-5.2
#   PROVIDER=xai              MODEL=xai/grok-4.3
#   PROVIDER=xiaomi-token-plan-sgp  MODEL=xiaomi-token-plan-sgp/mimo-v2.5-pro
#   PROVIDER=fireworks-ai     MODEL=fireworks-ai/accounts/fireworks/models/deepseek-v4-flash
#   PROVIDER=devin            MODEL=devin/default                            (or display names: devin/Claude Opus 4.6)
#   PROVIDER=commandcode      MODEL=commandcode/moonshotai/Kimi-K2.7-Code    (commandcode/<vendor>/<model>)
#   PROVIDER=cursor           MODEL=cursor/gpt-5.3-codex-high
#   PROVIDER=qoder            MODEL=qoder/auto                             (auto, ultimate, performance, efficient, lite)
#   PROVIDER=codex            MODEL=codex/default
#   PROVIDER=cline            MODEL=cline/deepseek/deepseek-v4-flash         (cline/<type>/<model>)
#   PROVIDER=cline-pass       MODEL=cline-pass/glm-5.2
#   PROVIDER=grok             MODEL=grok/default
#   PROVIDER=kilo             MODEL=kilo/stepfun/step-3.7-flash:free         (kilo/<vendor>/<model> — bare ids 404)
MODEL=opencode/deepseek-v4-flash-free
PORT=3000

# Auxiliary model for the aux sessions (addressed check, guideline pass,
# verification, lenses) — lets the main review run on a stronger tier while
# the mechanical checks stay cheap. When its provider differs from PROVIDER,
# also set JBOT_AUX_PROVIDER and that provider's key above.
#JBOT_REVIEW_AUX_MODEL=deepseek/deepseek-v4-flash
#JBOT_AUX_PROVIDER=deepseek

# Local review (`npm run review:local`) — optional knobs. The command loads
# this .env by itself; production entries never read .env. Full knob list:
# README "Local review".
#JBOT_LOCAL_BASE=origin/main
#JBOT_LOCAL_REPORT=true
# Fast local iteration: skip the adversarial verification pass (default true)
# and cap the wall clock (default 30 minutes).
#JBOT_VERIFY_FINDINGS=false
#JBOT_TIME_BUDGET_MINUTES=5
# SDK engine routing: `auto` (default) serves pi-allowlisted providers with the
# in-process pi SDK (needs Node >= 22.19) and the rest with opencode;
# `opencode` pins everything to the opencode server.
#JBOT_SDK_ENGINE=opencode

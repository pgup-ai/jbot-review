# Required
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Provider (defaults to opencode if unset)
# See src/shared/config.ts for all supported providers.
PROVIDER=opencode
OPENCODE_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
ZAI_API_KEY=
XAI_API_KEY=
DEVIN_WINDSURF_API_KEY=
COMMANDCODE_ACCESS_KEY=

# Optional (defaults to provider default model)
MODEL=opencode/deepseek-v4-flash-free
PORT=3000

# Golden benchmark defaults
BENCH_GOLDEN_SNAPSHOT_CONCURRENCY=2
BENCH_GOLDEN_MAX_CONCURRENT_SESSIONS=2
BENCH_GOLDEN_TIME_BUDGET_MINUTES=30
BENCH_GOLDEN_REVIEW_SHARDS=0
BENCH_GOLDEN_REVIEW_PASSES=1
BENCH_GOLDEN_VERIFY_FINDINGS=true
BENCH_GOLDEN_GUIDELINE_PASS=true

# To switch providers, change PROVIDER and the corresponding key:
#   PROVIDER=opencode-go → set OPENCODE_API_KEY
#   PROVIDER=deepseek     → set DEEPSEEK_API_KEY
#   PROVIDER=openai       → set OPENAI_API_KEY
#   PROVIDER=anthropic    → set ANTHROPIC_API_KEY
#   PROVIDER=google       → set GEMINI_API_KEY
#   PROVIDER=openrouter   → set OPENROUTER_API_KEY
#   PROVIDER=nvidia       → set NVIDIA_API_KEY
#   PROVIDER=zai-coding-plan → set ZAI_API_KEY
#   PROVIDER=xai          → set XAI_API_KEY
#   PROVIDER=devin        → set DEVIN_WINDSURF_API_KEY
#   PROVIDER=commandcode  → set COMMANDCODE_ACCESS_KEY
